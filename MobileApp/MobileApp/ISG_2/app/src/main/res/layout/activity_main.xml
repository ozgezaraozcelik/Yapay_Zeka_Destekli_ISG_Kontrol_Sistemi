<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/isg_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/dashboard_title"
        android:textColor="@color/isg_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="Yapay Zeka Destekli KKD Denetimi"
        android:textColor="@color/isg_primary_dark"
        android:textSize="13sp" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:layout_weight="1"
        android:background="@color/isg_preview_bg"
        android:contentDescription="@string/app_name"
        android:scaleType="fitCenter" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <!-- Genel & Şantiye Alanı -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/isg_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawablePadding="8dp"
                        android:text="@string/section_general"
                        android:textColor="@color/isg_section_title"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/isg_card_stroke" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_helmet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cb_helmet"
                        android:textSize="15sp" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_vest"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cb_vest"
                        android:textSize="15sp" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_belt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cb_belt"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Ağır Sanayi & Kaynakhane -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/isg_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_heavy_industry"
                        android:textColor="@color/isg_section_title"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/isg_card_stroke" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_welding"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cb_welding"
                        android:textSize="15sp" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_ear"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cb_ear"
                        android:textSize="15sp" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_gloves"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cb_gloves"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Kimya & Laboratuvar Sektörü -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/isg_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_chemistry"
                        android:textColor="@color/isg_section_title"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/isg_card_stroke" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_suit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cb_suit"
                        android:textSize="15sp" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_mask"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cb_mask"
                        android:textSize="15sp" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_glasses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cb_glasses"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Lojistik & Depolama Yönetimi -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/isg_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_logistics"
                        android:textColor="@color/isg_section_title"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/isg_card_stroke" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_toolbox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cb_toolbox"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
